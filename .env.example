# Copy to .env and fill in. Register a free app at https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Comma-separated Adzuna country codes (gb, de, nl, fr, at, pl, es, it ...).
JOB_COUNTRIES=gb,de,nl,fr
# Search term used for every country.
JOB_QUERY=data engineer
# Max result pages to pull per country per run (Adzuna returns ~50/page).
JOB_MAX_PAGES=3

# Root of the local Delta "lakehouse". Lives under the bind-mounted ./data dir.
LAKE_ROOT=/app/data/lake
